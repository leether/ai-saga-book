# Environment configuration for AI Saga book tooling
# Copy this file to .env and adjust values as needed

# Logging
LOG_LEVEL=INFO

# Output directories
BOOK_OUTPUT_DIR=./book-output
PDF_OUTPUT=./智能涌动.pdf

# Chapters
CHAPTERS_DIR=./book/src
CHAPTERS_COUNT=34

# Images
IMAGES_DIR=./images

# Typst PDF generation
TYPST_INPUT=./智能涌动.typ
TYPST_FONT_PATH=/System/Library/Fonts
